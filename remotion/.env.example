# Mismo proyecto de Supabase que usa la app principal — ver .env de la raíz
# del repo (SUPABASE_URL / SUPABASE_PROJECT_ID). Se repite acá porque este es
# un proyecto Node independiente con su propio entorno de ejecución (no
# comparte proceso ni bundle con la app principal).
SUPABASE_URL=

# NUNCA la anon key ni la publishable key. El worker necesita:
#   - leer eventos/gallery/messages de CUALQUIER organizador (fetchEventData.ts)
#   - escribir en el bucket "exports" (uploadToSupabase.ts)
#   - ejecutar mark_video_heartbeat/progress/completed/failed (renderer/index.ts)
# Las 4 funciones internas revocan EXECUTE de anon y authenticated y solo lo
# otorgan a service_role (ver
# supabase/migrations/20260721230000_video_summary_fixes.sql) — sin esta key,
# el worker no puede reportar ningún estado.
SUPABASE_SERVICE_ROLE_KEY=

# Configuración del worker (src/worker/cli.ts) — todas opcionales, con
# defaults sensatos si se omiten.
VIDEO_WORKER_CONCURRENCY=1
VIDEO_WORKER_POLL_INTERVAL_MS=5000
VIDEO_WORKER_STALE_TIMEOUT_S=90
